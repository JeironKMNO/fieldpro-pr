# ═══════════════════════════════════════════════════════════════════
# FieldPro PR - Variables de Entorno para Producción
# ═══════════════════════════════════════════════════════════════════
# Copiar este archivo a .env.local para desarrollo
# O configurar en Vercel Dashboard para producción
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# 1. CLERK AUTHENTICATION (Obligatorio)
# Obtener en: https://dashboard.clerk.com
# ═══════════════════════════════════════════════════════════════════
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ═══════════════════════════════════════════════════════════════════
# 2. DATABASE - Supabase (Obligatorio)
# Obtener en: https://app.supabase.com/project/_/settings/database
# ═══════════════════════════════════════════════════════════════════
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ═══════════════════════════════════════════════════════════════════
# 3. AI PROVIDER CONFIGURATION (Obligatorio - al menos uno)
# ═══════════════════════════════════════════════════════════════════
AI_PROVIDER=openai

# Google Gemini AI
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OpenAI GPT-4o
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ═══════════════════════════════════════════════════════════════════
# 4. EMAIL SERVICE - Resend (Obligatorio para notificaciones)
# Obtener en: https://resend.com/api-keys
# ═══════════════════════════════════════════════════════════════════
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL="FieldPro <noreply@fieldpro.app>"

# ═══════════════════════════════════════════════════════════════════
# 5. HOME DEPOT PRICING - SerpAPI (Opcional)
# Obtener en: https://serpapi.com/manage-api-key
# ═══════════════════════════════════════════════════════════════════
SERPAPI_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ═══════════════════════════════════════════════════════════════════
# 6. APP CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
NEXT_PUBLIC_APP_URL=https://fieldpro-pr.vercel.app
NODE_ENV=production

# ═══════════════════════════════════════════════════════════════════
# 7. MONITOREO Y ANALYTICS (Opcional)
# ═══════════════════════════════════════════════════════════════════
# SENTRY_DSN=https://XXXXX@XXXXX.ingest.sentry.io/XXXXX
# POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
