generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================
// MULTI-TENANT CORE
// =====================================================

model Organization {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clerkId  String  @unique
  name     String
  slug     String  @unique
  plan     Plan    @default(FREE)
  logoUrl  String? @db.Text
  phone    String?
  license  String?

  // Follow-up settings
  followUpDays       Int     @default(2)
  expiryReminderDays Int     @default(3)
  autoFollowUp       Boolean @default(true)

  users           User[]
  clients         Client[]
  notes           Note[]
  tags            Tag[]
  quotes          Quote[]
  quoteCategories QuoteCategory[]
  quoteCounter    QuoteCounter?
  jobs            Job[]
  jobCounter      JobCounter?
  invoices        Invoice[]
  invoiceCounter  InvoiceCounter?
  materialLists   MaterialList[]

  @@index([clerkId])
  @@index([slug])
  @@map("organizations")
}

enum Plan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clerkId        String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email     String
  firstName String?
  lastName  String?
  role      UserRole @default(CREW)

  notes    Note[]
  quotes   Quote[]
  jobs     Job[]
  invoices Invoice[]

  @@unique([organizationId, clerkId])
  @@index([clerkId])
  @@index([organizationId])
  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  CREW
}

// =====================================================
// CRM
// =====================================================

model Client {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name   String
  email  String?
  phone  String?
  type   ClientType   @default(RESIDENTIAL)
  status ClientStatus @default(ACTIVE)

  addresses Address[]
  notes     Note[]
  tags      ClientTag[]
  quotes    Quote[]
  jobs      Job[]
  invoices  Invoice[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@map("clients")
}

enum ClientType {
  RESIDENTIAL
  COMMERCIAL
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model Address {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  street    String
  city      String
  state     String  @default("PR")
  zipCode   String
  country   String  @default("US")
  latitude  Float?
  longitude Float?
  isPrimary Boolean @default(false)

  @@index([clientId])
  @@map("addresses")
}

model Note {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  content String   @db.Text
  type    NoteType @default(GENERAL)

  @@index([organizationId])
  @@index([clientId])
  @@index([userId])
  @@map("notes")
}

enum NoteType {
  GENERAL
  IMPORTANT
  FOLLOW_UP
}

// =====================================================
// TAGS / LABELS
// =====================================================

model Tag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name  String
  color String @default("#6B7280")

  clients ClientTag[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("tags")
}

model ClientTag {
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
  @@map("client_tags")
}

// =====================================================
// QUOTES / ESTIMATES
// =====================================================

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum UnitType {
  SQ_FT
  LINEAR_FT
  CUBIC_YD
  UNIT
  HOUR
  LUMP_SUM
}

model QuoteCounter {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lastNumber     Int          @default(0)

  @@map("quote_counters")
}

model QuoteCategory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name      String
  sortOrder Int     @default(0)
  isDefault Boolean @default(false)

  sections QuoteSection[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("quote_categories")
}

model Quote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  quoteNumber String
  status      QuoteStatus @default(DRAFT)
  title       String?

  taxRate   Decimal @default(0.115) @db.Decimal(5, 4)
  subtotal  Decimal @default(0) @db.Decimal(12, 2)
  taxAmount Decimal @default(0) @db.Decimal(12, 2)
  total     Decimal @default(0) @db.Decimal(12, 2)

  notes     String? @db.Text
  validUntil DateTime?

  shareToken  String   @unique @default(cuid())
  sentAt         DateTime?
  viewedAt       DateTime?
  respondedAt    DateTime?
  lastFollowUpAt DateTime?

  sections   QuoteSection[]
  activities QuoteActivity[]
  job        Job?

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([clientId])
  @@index([shareToken])
  @@map("quotes")
}

model QuoteSection {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quoteId String
  quote   Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  categoryId String
  category   QuoteCategory @relation(fields: [categoryId], references: [id])

  sortOrder Int     @default(0)
  subtotal  Decimal @default(0) @db.Decimal(12, 2)

  items QuoteItem[]

  @@index([quoteId])
  @@map("quote_sections")
}

model QuoteItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sectionId String
  section   QuoteSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  description String
  unitType    UnitType @default(SQ_FT)

  length Decimal? @db.Decimal(10, 2)
  width  Decimal? @db.Decimal(10, 2)
  height Decimal? @db.Decimal(10, 2)

  quantity  Decimal @db.Decimal(10, 2)
  unitPrice Decimal @db.Decimal(10, 2)
  markupPct Decimal @default(0) @db.Decimal(5, 2)
  total     Decimal @db.Decimal(12, 2)

  sortOrder Int @default(0)

  @@index([sectionId])
  @@map("quote_items")
}

// =====================================================
// QUOTE ACTIVITY TRACKING
// =====================================================

enum QuoteActivityType {
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  FOLLOW_UP_SENT
  REMINDER_SENT
}

model QuoteActivity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  quoteId String
  quote   Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  type   QuoteActivityType
  detail String?

  @@index([quoteId])
  @@map("quote_activities")
}

// =====================================================
// JOBS / PROJECTS
// =====================================================

enum JobStatus {
  SCHEDULED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

model JobCounter {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lastNumber     Int          @default(0)

  @@map("job_counters")
}

model Job {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  quoteId String? @unique
  quote   Quote?  @relation(fields: [quoteId], references: [id])

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  jobNumber     String
  title         String?
  status        JobStatus @default(SCHEDULED)
  scheduledDate DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  notes         String?   @db.Text
  value         Decimal   @default(0) @db.Decimal(12, 2)

  invoice      Invoice?
  materialList MaterialList?
  tasks        JobTask[]
  changeOrders ChangeOrder[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([clientId])
  @@map("jobs")
}

// =====================================================
// JOB TASKS
// =====================================================

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model JobTask {
  id          String     @id @default(cuid())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  jobId       String
  job         Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title       String
  notes       String?    @db.Text
  status      TaskStatus @default(PENDING)
  sortOrder   Int        @default(0)
  dueDate     DateTime?
  completedAt DateTime?

  @@index([jobId])
  @@map("job_tasks")
}

// =====================================================
// CHANGE ORDERS
// =====================================================

enum ChangeOrderStatus {
  PENDING
  APPROVED
  REJECTED
}

model ChangeOrder {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title       String
  description String?           @db.Text
  amount      Decimal           @db.Decimal(12, 2)
  status      ChangeOrderStatus @default(PENDING)
  approvedAt  DateTime?

  @@index([jobId])
  @@map("change_orders")
}

// =====================================================
// INVOICING
// =====================================================

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

model InvoiceCounter {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lastNumber     Int          @default(0)

  @@map("invoice_counters")
}

model Invoice {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  jobId String? @unique
  job   Job?    @relation(fields: [jobId], references: [id])

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  invoiceNumber String
  status        InvoiceStatus @default(DRAFT)

  subtotal  Decimal @default(0) @db.Decimal(12, 2)
  taxRate   Decimal @default(0.115) @db.Decimal(5, 3)
  taxAmount Decimal @default(0) @db.Decimal(12, 2)
  total     Decimal @default(0) @db.Decimal(12, 2)

  dueDate DateTime?
  notes   String?   @db.Text

  shareToken String @unique @default(cuid())
  sentAt     DateTime?
  viewedAt   DateTime?
  paidAt     DateTime?

  items      InvoiceItem[]
  activities InvoiceActivity[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([clientId])
  @@map("invoices")
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  @@index([invoiceId])
  @@map("invoice_items")
}

enum InvoiceActivityType {
  CREATED
  SENT
  VIEWED
  PAID
  CANCELLED
}

model InvoiceActivity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  type   InvoiceActivityType
  detail String?

  @@index([invoiceId])
  @@map("invoice_activities")
}

// =====================================================
// MATERIAL SHOPPING LIST
// =====================================================

model MaterialList {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  items MaterialItem[]

  @@index([organizationId])
  @@map("material_lists")
}

model MaterialItem {
  id String @id @default(cuid())

  materialListId String
  materialList   MaterialList @relation(fields: [materialListId], references: [id], onDelete: Cascade)

  name           String
  quantity       Decimal  @db.Decimal(10, 2)
  unit           String
  estimatedPrice Decimal? @db.Decimal(12, 2)
  store          String?
  purchased      Boolean  @default(false)
  notes          String?
  sortOrder      Int      @default(0)

  @@index([materialListId])
  @@map("material_items")
}
